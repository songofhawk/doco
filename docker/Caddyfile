{
	admin off
	auto_https off
}

:8080 {
	encode zstd gzip

	@backend path /healthz /app-api/* /api/* /ws*
	handle @backend {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
