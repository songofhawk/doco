# Docker Compose
DOCO_HTTP_PORT=8080
DOCO_IMAGE_NAMESPACE=songofhawkg
DOCO_IMAGE_TAG=latest
DOCO_DATA_VOLUME=doco-data

# 必须包含浏览器实际访问 Doco 时使用的 Origin。生产 HTTPS 示例：https://doco.example.com
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
TRUST_PROXY=loopback

# 同源 HTTP 本地部署使用 false；启用 HTTPS 后改为 true。
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
SESSION_TTL_DAYS=30

# Google OAuth Web Client ID。由后端在容器启动时作为公开配置提供给前端。
GOOGLE_CLIENT_ID=

# 邮箱验证码登录。未配置 SMTP 时，发送验证码接口会返回配置错误。
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_CODE_TTL_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_PER_HOUR=5
EMAIL_CODE_IP_MAX_PER_HOUR=20
EMAIL_CODE_MAX_ATTEMPTS=5

# 工作区和文档配额
DOCO_MAX_KNOWLEDGE_BASES=100
DOCO_MAX_DOCUMENTS_AND_FOLDERS=10000
DOCO_MAX_FOLDER_DEPTH=20
DOCO_MAX_DOCUMENT_CHARACTERS=100000
DOCO_MAX_YDOC_SNAPSHOT_BYTES=5242880
DOCO_MAX_ATTACHMENT_BYTES=20971520
DOCO_MAX_TRANSFER_BYTES=262144000
DOCO_MAX_TRANSFER_ENTRIES=20000

# 开放 API
OPEN_API_RATE_LIMIT_PER_MINUTE=120
OPEN_API_WRITE_RATE_LIMIT_PER_MINUTE=30
OPEN_API_DOCUMENT_WRITE_RATE_LIMIT_PER_MINUTE=10
OPEN_API_UNAUTHENTICATED_RATE_LIMIT_PER_MINUTE=30
OPEN_API_MAX_ATTACHMENT_BYTES=20971520
# OPEN_API_ATTACHMENT_MIME_TYPES=image/png,image/jpeg,image/gif,image/webp,application/pdf,text/plain
