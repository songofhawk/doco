# 后端配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# 浏览器 REST/WebSocket 请求允许的前端 Origin，多个地址用英文逗号分隔
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Google OAuth Web Client ID。前后端必须使用同一个 Client ID。
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# 本地开发默认 Lax；生产 HTTPS 跨站前后端通常需要 COOKIE_SAMESITE=none 和 COOKIE_SECURE=true。
SESSION_TTL_DAYS=30
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# 邮箱验证码登录（SMTP）。SMTP_FROM 必填，可写成 "Doco <no-reply@example.com>"。
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Doco <no-reply@example.com>"
# 验证码默认 10 分钟有效、60 秒可重发、每邮箱每小时最多 5 次、每 IP 每小时最多 20 次。
EMAIL_CODE_TTL_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_PER_HOUR=5
EMAIL_CODE_IP_MAX_PER_HOUR=20
EMAIL_CODE_MAX_ATTEMPTS=5

# 数据与开放 API 配置
# 下列相对路径按后端进程工作目录解析（推荐在 backend/ 下启动）。
DOCO_DB_PATH=./doco.db
DOCO_ATTACHMENTS_PATH=./attachments
OPEN_API_RATE_LIMIT_PER_MINUTE=120
OPEN_API_WRITE_RATE_LIMIT_PER_MINUTE=30
OPEN_API_DOCUMENT_WRITE_RATE_LIMIT_PER_MINUTE=10
OPEN_API_UNAUTHENTICATED_RATE_LIMIT_PER_MINUTE=30
OPEN_API_MAX_ATTACHMENT_BYTES=20971520
# 逗号分隔的附件 MIME 白名单；不配置时使用服务端默认白名单。
# OPEN_API_ATTACHMENT_MIME_TYPES=image/png,image/jpeg,image/gif,image/webp,application/pdf,text/plain

# 前端配置
VITE_API_BASE=http://localhost:8000/app-api/v1
VITE_WS_URL=ws://localhost:8000/ws
